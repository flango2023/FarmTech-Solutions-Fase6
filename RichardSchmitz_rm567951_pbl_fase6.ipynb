   "id": "m3n4o5p6",
   "metadata": {},
   "outputs": [],
   "source": "import matplotlib.pyplot as plt\nimport matplotlib.image as mpimg\nimport glob\nimport random\n\nrandom.seed(42)\n\ntrain_dir = f\"{DRIVE_DATASET}/images/train\"\n\ncar_list   = glob.glob(f\"{train_dir}/car_*.jpg\")\ndrone_list = glob.glob(f\"{train_dir}/drone_*.jpg\")\n\nif len(car_list) < 4 or len(drone_list) < 4:\n    raise RuntimeError(\n        f\"Imagens insuficientes no train — car: {len(car_list)}, drone: {len(drone_list)}. \"\n        \"Verifique se a célula 1.2 (download do dataset) foi executada com sucesso.\"\n    )\n\ncar_imgs   = random.sample(car_list, 4)\ndrone_imgs = random.sample(drone_list, 4)\n\nfig, axes = plt.subplots(2, 4, figsize=(16, 8))\nfig.suptitle('Amostras do Dataset de Treinamento', fontsize=14, fontweight='bold')\n\nfor i, path in enumerate(car_imgs):\n    axes[0][i].imshow(mpimg.imread(path))\n    axes[0][i].set_title('Classe: car', color='blue')\n    axes[0][i].axis('off')\n\nfor i, path in enumerate(drone_imgs):\n    axes[1][i].imshow(mpimg.imread(path))\n    axes[1][i].set_title('Classe: drone', color='orange')\n    axes[1][i].axis('off')\n\nplt.tight_layout()\nplt.show()\nprint(\"Amostras: 4 carros (linha 1) e 4 drones (linha 2)\")"
