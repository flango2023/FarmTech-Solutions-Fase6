   "source": "import os\nimport shutil\n\nDRIVE_RESULTS = '/content/drive/MyDrive/FarmTech-Fase6/results'\nos.makedirs(DRIVE_RESULTS, exist_ok=True)\n\n# Copia os resultados de treinamento para o Drive\nfor run_name in ['farmtech_30ep', 'farmtech_60ep']:\n    src = f'/content/yolov5/runs/train/{run_name}'\n    dst = f'{DRIVE_RESULTS}/train_{run_name}'\n    if os.path.exists(src):\n        shutil.copytree(src, dst, dirs_exist_ok=True)\n        print(f\"Copiado: {run_name} → Drive/results/train_{run_name}\")\n    else:\n        print(f\"AVISO: {src} não encontrado — execute o treinamento antes.\")\n\n# Copia os resultados de inferência para o Drive\nfor run_name in ['test_30ep', 'test_60ep']:\n    src = f'/content/yolov5/runs/detect/{run_name}'\n    dst = f'{DRIVE_RESULTS}/detect_{run_name}'\n    if os.path.exists(src):\n        shutil.copytree(src, dst, dirs_exist_ok=True)\n        print(f\"Copiado: {run_name} → Drive/results/detect_{run_name}\")\n    else:\n        print(f\"AVISO: {src} não encontrado — execute a inferência antes.\")\n\n# Copia o gráfico comparativo (só existe se a célula 5.1 rodou)\nplot_path = '/content/comparacao_30_vs_60_epocas.png'\nif os.path.exists(plot_path):\n    shutil.copy(plot_path, DRIVE_RESULTS)\n    print(\"Gráfico comparativo copiado.\")\nelse:\n    print(\"AVISO: gráfico comparativo não encontrado — execute a célula 5.1 antes.\")\n\nprint(f\"\\nResultados salvos em: MyDrive/FarmTech-Fase6/results/\")"
