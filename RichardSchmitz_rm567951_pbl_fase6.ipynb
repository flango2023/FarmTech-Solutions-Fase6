   "source": [
    "### 5.2 Tabela Resumo de Métricas"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "y5z6a7b8",
   "metadata": {},
   "outputs": [],
   "source": "import pandas as pd\n\ndef get_best_metrics(df, label):\n    precision = df['metrics/precision'].max()\n    recall    = df['metrics/recall'].max()\n    map50     = df['metrics/mAP_0.5'].max()\n    map5095   = df.get('metrics/mAP_0.5:0.95', pd.Series([0])).max()\n    box_loss  = df['train/box_loss'].min()\n    return {\n        'Experimento':    label,\n        'Precision':      f'{precision:.4f}',\n        'Recall':         f'{recall:.4f}',\n        'mAP@0.5':        f'{map50:.4f}',\n        'mAP@0.5:0.95':   f'{map5095:.4f}',\n        'Box Loss (min)': f'{box_loss:.4f}',\n    }\n\nsummary = pd.DataFrame([\n    get_best_metrics(df_30, '30 Épocas'),\n    get_best_metrics(df_60, '60 Épocas'),\n])\n\nprint(\"=\" * 70)\nprint(\"RESUMO COMPARATIVO DE DESEMPENHO — MELHORES VALORES\")\nprint(\"=\" * 70)\nprint(summary.to_string(index=False))\nprint(\"=\" * 70)\nprint(\"\\nLegenda:\")\nprint(\"  mAP@0.5      — Mean Average Precision com IoU threshold 0.5\")\nprint(\"  mAP@0.5:0.95 — mAP médio em vários thresholds (métrica mais rigorosa)\")\nprint(\"  Box Loss     — Erro de localização do bounding box\")"
  },
