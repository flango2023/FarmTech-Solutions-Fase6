   "source": "import matplotlib.pyplot as plt\n\nfig, axes = plt.subplots(2, 3, figsize=(18, 10))\nfig.suptitle('Comparação de Desempenho: 30 Épocas vs 60 Épocas', fontsize=15, fontweight='bold')\n\n# Pares de (coluna no CSV, título do gráfico, tipo: maior=melhor ou menor=melhor)\nmetrics_info = [\n    ('metrics/precision',    'Precisão (Precision)',      'higher'),\n    ('metrics/recall',       'Recall',                    'higher'),\n    ('metrics/mAP_0.5',      'mAP @ IoU 0.5',            'higher'),\n    ('train/box_loss',       'Perda — Bounding Box',      'lower'),\n    ('train/obj_loss',       'Perda — Objectness',        'lower'),\n    ('train/cls_loss',       'Perda — Classificação',     'lower'),\n]\n\nfor ax, (col, title, direction) in zip(axes.flat, metrics_info):\n    if col in df_30.columns:\n        ax.plot(df_30[col].values, label='30 épocas', color='royalblue', linewidth=2)\n    if col in df_60.columns:\n        ax.plot(df_60[col].values, label='60 épocas', color='darkorange', linewidth=2)\n\n    ax.set_title(title, fontsize=11, fontweight='bold')\n    ax.set_xlabel('Época')\n    ax.legend()\n    ax.grid(True, alpha=0.3)\n\n    note = '↑ quanto maior, melhor' if direction == 'higher' else '↓ quanto menor, melhor'\n    ax.text(0.02, 0.05, note, transform=ax.transAxes, fontsize=8, color='gray', style='italic')\n\nplt.tight_layout()\nplt.savefig('/content/comparacao_30_vs_60_epocas.png', dpi=150, bbox_inches='tight')\nplt.show()\nprint(\"Gráfico salvo em: /content/comparacao_30_vs_60_epocas.png\")"
