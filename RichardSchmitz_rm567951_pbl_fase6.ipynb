   "cell_type": "code",
   "id": "1f2803a9",
   "source": "import os\nimport shutil\nimport glob as _glob\n\nDRIVE_FASE6 = '/content/drive/MyDrive/FarmTech-Fase6'\nos.makedirs(DRIVE_FASE6, exist_ok=True)\n\ndst_dataset = f'{DRIVE_FASE6}/dataset'\n\n# Verifica se o dataset está completo (32 carros + 32 drones no train)\ndrone_count = len(_glob.glob(f\"{dst_dataset}/images/train/drone_*.jpg\"))\ncar_count   = len(_glob.glob(f\"{dst_dataset}/images/train/car_*.jpg\"))\nis_complete = drone_count >= 32 and car_count >= 32\n\nif is_complete:\n    print(f\"Dataset já completo no Drive ({car_count} carros, {drone_count} drones). Pulando download.\")\nelse:\n    print(f\"Dataset incompleto (car={car_count}, drone={drone_count}). Baixando do GitHub...\")\n    # Remove dataset corrompido e repo temporário anteriores, se existirem\n    if os.path.exists(dst_dataset):\n        shutil.rmtree(dst_dataset)\n    if os.path.exists('/tmp/fase6_repo'):\n        shutil.rmtree('/tmp/fase6_repo')\n\n    !git clone --depth 1 https://github.com/flango2023/FarmTech-Solutions-Fase6 /tmp/fase6_repo\n    shutil.copytree('/tmp/fase6_repo/dataset', dst_dataset)\n    shutil.rmtree('/tmp/fase6_repo')\n    print(\"Dataset copiado com sucesso!\")\n\n# Verifica estrutura final\nfor split in ['train', 'val', 'test']:\n    n_imgs = len(os.listdir(f\"{dst_dataset}/images/{split}\"))\n    n_lbls = len(os.listdir(f\"{dst_dataset}/labels/{split}\"))\n    print(f\"  [{split}] {n_imgs} imagens | {n_lbls} labels\")",
